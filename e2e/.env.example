# App URL
APP_URL=http://localhost:3000

# ── LLM for Stagehand ──────────────────────────────
# Stagehand uses OpenAI SDK under the hood.
# Point these at any OpenAI-compatible provider.
#
# Examples:
#   OpenAI direct:     OPENAI_API_KEY=sk-xxx
#   OpenRouter:        OPENAI_API_KEY=sk-or-xxx  OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   Omnimaas proxy:    OPENAI_API_KEY=sk-xxx     OPENAI_BASE_URL=https://api.omnimaas.com/v1
#
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=anthropic/claude-sonnet-4.6

# ── Viewport ────────────────────────────────────────
# VIEWPORT_WIDTH=1440
# VIEWPORT_HEIGHT=900
