# ============================================================
# PuppyOne Backend — Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_MODULE="src.main"
DEBUG="false"
PORT="9090"
PUBLIC_URL="http://localhost:9090"

# SERVICE_ROLE controls which service starts (api | file_worker | mcp_server)
# Leave unset to start the default API service.
# SERVICE_ROLE=api

# ── Internal ─────────────────────────────────────────────────
# Random secret shared between internal services
INTERNAL_API_SECRET="change-me-random-secret"

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_KEY="<supabase-service-role-key>"
SUPABASE_ANON_KEY="<supabase-anon-key>"

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET="<random-base64-secret-min-64-chars>"

# Set to "true" to bypass authentication in local development
SKIP_AUTH="false"

# ── S3 / Storage ─────────────────────────────────────────────
USE_REAL_S3="false"
S3_ENDPOINT_URL="http://localhost:4566"   # LocalStack default; replace with real endpoint for production
S3_BUCKET_NAME="contextbase"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="<your-s3-access-key-id>"
S3_SECRET_ACCESS_KEY="<your-s3-secret-access-key>"

# ── LLM ─────────────────────────────────────────────────────
# Primary LLM provider (used via LiteLLM)
ANTHROPIC_API_KEY="<your-anthropic-api-key>"
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_MODEL="claude-opus-4-5-20251101"

# Optional alternative providers
OPENROUTER_API_KEY=""
DEEPINFRA_API_KEY=""

# ── OCR / ETL ────────────────────────────────────────────────
# OCR provider: "mineru" | "reducto" | "deepseek"
OCR_PROVIDER="deepseek"
ENABLE_ETL="true"

# MineRU (optional, for PDF extraction)
MINERU_API_KEY=""

# ── Redis (ARQ task queue) ───────────────────────────────────
ETL_REDIS_URL="redis://localhost:6379"

# ── MCP Server ──────────────────────────────────────────────
MCP_SERVER_URL="http://localhost:9091"

# ── Sandbox ──────────────────────────────────────────────────
# Sandbox backend: "auto" | "docker" | "e2b"
# - auto: use E2B when E2B_API_KEY is set, otherwise fall back to Docker
# - docker: use the local Docker daemon
# - e2b: always use E2B cloud sandboxes
SANDBOX_TYPE="auto"
# Dedicated sandbox temp directory. Only needed when the backend runs inside
# a container but launches sandbox containers via the host Docker daemon.
SANDBOX_TMPDIR=""
E2B_API_KEY=""

# ── OAuth — GitHub ───────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:3000/oauth/github/callback"

# ── OAuth — Notion ───────────────────────────────────────────
NOTION_API_KEY=""

# ── OAuth — Google (shared across all Google services) ───────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_SHEETS_REDIRECT_URI="http://localhost:3000/oauth/google-sheets/callback"
GMAIL_REDIRECT_URI="http://localhost:3000/oauth/gmail/callback"
GOOGLE_DRIVE_REDIRECT_URI="http://localhost:3000/oauth/google-drive/callback"
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/oauth/google-calendar/callback"
GOOGLE_DOCS_REDIRECT_URI="http://localhost:3000/oauth/google-docs/callback"
