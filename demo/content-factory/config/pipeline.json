{
  "pipeline": "tech-blog",
  "version": "1.0",
  "stages": ["research", "draft", "review", "publish"],
  "agents": {
    "research-bot": {
      "model": "claude-sonnet-4-5-20250514",
      "scope": "/raw/",
      "mode": "rw",
      "schedule": "daily"
    },
    "writer-bot": {
      "model": "claude-sonnet-4-5-20250514",
      "scope": "/draft/",
      "mode": "rw",
      "depends_on": "research-bot"
    },
    "review-bot": {
      "model": "claude-sonnet-4-5-20250514",
      "scope": "/draft/",
      "mode": "r",
      "output": "external:slack#content-review"
    }
  },
  "quality": {
    "min_word_count": 800,
    "max_word_count": 2500,
    "required_sections": ["introduction", "key-takeaways"],
    "tone": "professional, accessible"
  }
}
