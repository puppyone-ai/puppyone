# =============================================================
# PuppyOne Docker — Environment Variables
# All values below are pre-filled with local development defaults.
# Just copy this file to .env and run: docker compose up -d
# =============================================================

# ── Supabase Credentials ─────────────────────────────────────
# These are the standard Supabase local development tokens.
# Safe for local use only — DO NOT use in production.
POSTGRES_PASSWORD=postgres
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ── S3 / MinIO ────────────────────────────────────────────────
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=contextbase

# ── LLM (optional — add your key to enable agent chat) ───────
ANTHROPIC_API_KEY=

# ── Auth & Sandbox ────────────────────────────────────────────
# Keep auth enabled by default even in local Docker deployments.
SKIP_AUTH=false
# Local Docker sandbox is the default for the one-command stack.
# Set SANDBOX_TYPE=e2b and provide E2B_API_KEY to use E2B instead.
SANDBOX_TYPE=docker
E2B_API_KEY=
# Dedicated sandbox temp directory. This must be the same absolute path on
# both the host and the `api` container so bind mounts resolve correctly.
SANDBOX_TMPDIR=/tmp/puppyone-sandbox

# ── Ports (change if you have conflicts) ──────────────────────
SUPABASE_API_PORT=8000
FRONTEND_PORT=3000
BACKEND_PORT=9090
MINIO_CONSOLE_PORT=9001

# ── Internal Docker Networking ────────────────────────────────
# Used by the Next.js server runtime inside the `web` container.
API_INTERNAL_URL=http://api:9090
SUPABASE_INTERNAL_URL=http://kong:8000
